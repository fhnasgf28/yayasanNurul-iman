// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url sengaja tidak diset di sini karena project menggunakan
  // @prisma/adapter-pg (driver adapter mode).
  // Koneksi database dikelola di src/lib/db.ts via PrismaPg adapter
  // menggunakan DATABASE_URL dari environment variable.
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
  news      News[]
}

enum Role {
  ADMIN
  EDITOR
}

model Program {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String        @db.Text
  content     String        @db.Text
  thumbnail   String?
  category    String
  status      ProgramStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  beneficiary Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum ProgramStatus {
  ACTIVE
  COMPLETED
  DRAFT
}

model News {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String   @db.Text
  thumbnail   String?
  category    String
  tags        String[]
  published   Boolean  @default(false)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Gallery {
  id        String   @id @default(cuid())
  imageUrl  String
  caption   String?
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model SiteSettings {
  id          String @id @default(cuid())
  key         String @unique
  value       String @db.Text
  description String?
}

model Prestasi {
  id        String   @id @default(cuid())
  title     String
  caption   String
  imageUrl  String
  badge     String   @default("Prestasi")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentRegistration {
  id           String             @id @default(cuid())
  studentName  String
  nickname     String?
  gender       StudentGender
  birthPlace   String
  birthDate    DateTime
  schoolOrigin String?
  currentGrade String?
  program      String
  parentName   String
  parentPhone  String
  parentEmail  String?
  address      String             @db.Text
  notes        String?            @db.Text
  status       RegistrationStatus @default(NEW)
  submittedAt  DateTime           @default(now())
  reviewedAt   DateTime?
  updatedAt    DateTime           @updatedAt

  @@index([status])
  @@index([submittedAt])
}

enum StudentGender {
  MALE
  FEMALE
}

enum RegistrationStatus {
  NEW
  CONTACTED
  ACCEPTED
  REJECTED
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model DonationReport {
  id        String                  @id @default(cuid())
  title     String
  month     DateTime
  category  DonationReportCategory
  income    Decimal                 @default(0) @db.Decimal(14, 2)
  expense   Decimal                 @default(0) @db.Decimal(14, 2)
  notes     String?                 @db.Text
  published Boolean                 @default(true)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@index([published])
  @@index([month])
}

enum DonationReportCategory {
  OPERASIONAL_MASJID
  RENOVASI
  BEASISWA_SANTRI
  TAHFIDZ
}

model Donatur {
  id        String           @id @default(cuid())
  nama      String
  telepon   String?
  alamat    String?          @db.Text
  catatan   String?          @db.Text
  aktif     Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  donations DonaturDonation[]

  @@index([aktif])
}

model DonaturDonation {
  id        String   @id @default(cuid())
  donaturId String
  donatur   Donatur  @relation(fields: [donaturId], references: [id], onDelete: Cascade)
  bulan     DateTime
  nominal   Decimal  @db.Decimal(14, 2)
  catatan   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([donaturId, bulan])
  @@index([donaturId])
  @@index([bulan])
}

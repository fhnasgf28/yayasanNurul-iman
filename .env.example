# ===========================================================
# Template konfigurasi environment Yayasan Nurul Iman
# Salin file ini menjadi .env dan isi nilainya
# JANGAN commit file .env asli ke git!
# ===========================================================

# --- Database ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yayasan_db?schema=public"

# --- NextAuth ---
# Ganti dengan URL publik aplikasi (bukan localhost saat production)
# Contoh production: https://yayasannuruliman.clipperyt.online
NEXTAUTH_URL="https://yayasannuruliman.clipperyt.online"

# Secret acak untuk enkripsi JWT. Generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-secret-acak-yang-kuat"

# Agar NextAuth percaya proxy/tunnel (set true di production)
AUTH_TRUST_HOST="true"

# --- Opsional: URL publik website (untuk sitemap, og:url, dll) ---
# NEXT_PUBLIC_SITE_URL="https://yayasannuruliman.clipperyt.online"
